<?xml version="1.0" encoding="utf-8"?>
<!--
    colors.xml

    앱에서 사용하는 모든 색상 정의.

    [색상 명명 규칙]
    - 용도 기반: connected_green, error_red 등
    - Material Design 가이드라인 준수

    [수정 시 참고]
    - 색상 변경 시 접근성 고려 (대비율 4.5:1 이상)
    - 다크 모드 지원 시 values-night/colors.xml 추가
-->
<resources>
    <!-- ============================================================ -->
    <!-- 기본 테마 색상 (Material Design) -->
    <!-- ============================================================ -->

    <!--
        Primary 색상
        - 앱의 주요 브랜드 색상
        - 앱바, 버튼 등에 사용
    -->
    <color name="primary">#1976D2</color>
    <color name="primary_variant">#1565C0</color>
    <color name="on_primary">#FFFFFF</color>

    <!--
        Secondary 색상
        - 보조 강조 색상
        - FAB, 선택된 항목 등에 사용
    -->
    <color name="secondary">#FF6F00</color>
    <color name="secondary_variant">#E65100</color>
    <color name="on_secondary">#FFFFFF</color>

    <!-- ============================================================ -->
    <!-- 배경 색상 -->
    <!-- ============================================================ -->

    <!--
        앱 배경색
        - 전체 화면 배경
        - 밝은 회색으로 눈의 피로 감소
    -->
    <color name="background">#F5F5F5</color>

    <!--
        Surface 색상
        - 카드, 다이얼로그 등 표면 색상
    -->
    <color name="surface">#FFFFFF</color>
    <color name="on_surface">#212121</color>

    <!-- ============================================================ -->
    <!-- 연결 상태 색상 -->
    <!-- ============================================================ -->

    <!--
        연결됨 (초록색)
        - USB 연결 성공 상태
        - 긍정적인 상태 표시
    -->
    <color name="connected_green">#4CAF50</color>
    <color name="connected_green_light">#E8F5E9</color>

    <!--
        연결 안됨 (빨간색)
        - USB 연결 해제 상태
        - 주의가 필요한 상태
    -->
    <color name="disconnected_red">#F44336</color>
    <color name="disconnected_red_light">#FFEBEE</color>

    <!-- ============================================================ -->
    <!-- 버튼 색상 -->
    <!-- ============================================================ -->

    <!--
        트리거 버튼 색상
        - 눈에 띄는 색상으로 주요 동작 강조
        - 주황색 계열: 주의를 끌면서 경고는 아닌 색상
    -->
    <color name="trigger_button_color">#FF5722</color>
    <color name="trigger_button_pressed">#E64A19</color>
    <color name="trigger_button_disabled">#BDBDBD</color>

    <!-- ============================================================ -->
    <!-- 텍스트 색상 -->
    <!-- ============================================================ -->

    <!--
        주요 텍스트
        - 제목, 중요 정보
        - 높은 대비율
    -->
    <color name="text_primary">#212121</color>

    <!--
        보조 텍스트
        - 라벨, 부가 정보
        - 약간 낮은 대비율
    -->
    <color name="text_secondary">#757575</color>

    <!--
        힌트 텍스트
        - 입력 필드 힌트
        - 낮은 대비율
    -->
    <color name="text_hint">#9E9E9E</color>

    <!-- ============================================================ -->
    <!-- 로그 영역 색상 -->
    <!-- ============================================================ -->

    <!--
        로그 배경
        - 어두운 배경으로 터미널 느낌
        - 코드/로그 가독성 향상
    -->
    <color name="log_background">#263238</color>

    <!--
        로그 텍스트
        - 밝은 색상으로 어두운 배경에서 가독성 확보
        - 녹색 계열: 터미널 느낌
    -->
    <color name="log_text">#B2FF59</color>

    <!--
        로그 테두리
        - 로그 영역 구분
    -->
    <color name="log_border">#37474F</color>

    <!-- ============================================================ -->
    <!-- 상태 표시 색상 -->
    <!-- ============================================================ -->

    <!--
        성공 색상
        - 작업 완료, 전송 성공 등
    -->
    <color name="success">#4CAF50</color>

    <!--
        경고 색상
        - 주의 필요한 상황
    -->
    <color name="warning">#FFC107</color>

    <!--
        오류 색상
        - 오류 발생, 실패 등
    -->
    <color name="error">#F44336</color>

    <!--
        정보 색상
        - 일반 정보 표시
    -->
    <color name="info">#2196F3</color>

    <!-- ============================================================ -->
    <!-- 구분선 및 테두리 -->
    <!-- ============================================================ -->

    <color name="divider">#E0E0E0</color>
    <color name="border">#BDBDBD</color>

</resources>
