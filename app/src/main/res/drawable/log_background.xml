<?xml version="1.0" encoding="utf-8"?>
<!--
    log_background.xml

    로그 출력 영역의 배경 drawable.

    [용도]
    - logScrollView의 배경
    - 터미널 느낌의 어두운 배경

    [스타일]
    - 어두운 배경색 (터미널 스타일)
    - 둥근 모서리 (8dp)
    - 미세한 테두리
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- 배경색: 어두운 터미널 스타일 -->
    <solid android:color="@color/log_background" />

    <!-- 모서리 둥글기 -->
    <corners android:radius="8dp" />

    <!-- 테두리: 약간 밝은 색으로 영역 구분 -->
    <stroke
        android:width="1dp"
        android:color="@color/log_border" />

</shape>
