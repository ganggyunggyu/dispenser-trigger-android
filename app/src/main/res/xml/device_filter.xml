<?xml version="1.0" encoding="utf-8"?>
<!--
    device_filter.xml

    USB 장치 필터링 설정 파일.
    어떤 USB 장치가 연결되었을 때 앱에 알림을 받을지 결정한다.

    [왜 필요한가]
    - 모든 USB 장치에 반응하면 키보드, 마우스 등에도 앱이 뜸
    - 특정 Vendor ID / Product ID로 RS-232 어댑터만 필터링

    [지원하는 칩셋]
    1. FTDI (Future Technology Devices International)
       - Vendor ID: 0x0403
       - 가장 널리 사용되는 USB-Serial 칩

    2. Prolific PL2303
       - Vendor ID: 0x067B
       - 저렴한 중국산 어댑터에 많이 사용

    3. Silicon Labs CP210x
       - Vendor ID: 0x10C4
       - 안정성 좋음, 드라이버 지원 우수

    4. WCH CH340/CH341
       - Vendor ID: 0x1A86
       - 가장 저렴, 호환성 좋음

    5. Qinheng CH9102
       - Vendor ID: 0x1A86, Product ID: 0x55D4
       - CH340 후속 칩

    [수정 시 참고]
    - 특정 어댑터만 사용한다면 해당 칩셋만 남기고 삭제 가능
    - 새로운 칩셋 추가 시 Vendor ID, Product ID 확인 필요
    - vendor-id, product-id는 10진수로 입력 (16진수 아님!)

    [Vendor ID 변환 예시]
    - 0x0403 (16진수) = 1027 (10진수)
    - 0x067B (16진수) = 1659 (10진수)
-->
<resources>
    <!--
        FTDI 칩셋 (FT232R, FT232H, FT2232 등)
        - Vendor ID: 0x0403 = 1027
        - 가장 안정적이고 널리 호환되는 칩셋
        - 산업용 장비에서 많이 사용
    -->
    <usb-device vendor-id="1027" />

    <!--
        Prolific PL2303 칩셋
        - Vendor ID: 0x067B = 1659
        - 저렴한 USB-Serial 케이블에 많이 탑재
        - 일부 구형 드라이버에서 호환성 이슈 있음
    -->
    <usb-device vendor-id="1659" />

    <!--
        Silicon Labs CP210x 칩셋 (CP2102, CP2104 등)
        - Vendor ID: 0x10C4 = 4292
        - 드라이버 안정성 우수
        - Arduino 호환 보드에서 자주 사용
    -->
    <usb-device vendor-id="4292" />

    <!--
        WCH CH340/CH341 칩셋
        - Vendor ID: 0x1A86 = 6790
        - 가장 저렴한 USB-Serial 칩
        - 중국산 Arduino 클론에 많이 사용
        - 대부분의 저가 RS-232 어댑터에 탑재
    -->
    <usb-device vendor-id="6790" />

    <!--
        QinHeng CH9102 칩셋
        - Vendor ID: 0x1A86 = 6790
        - Product ID: 0x55D4 = 21972
        - CH340 후속 칩, USB 2.0 Full Speed 지원
    -->
    <usb-device vendor-id="6790" product-id="21972" />

    <!--
        FTDI FT231X
        - Vendor ID: 0x0403 = 1027
        - Product ID: 0x6015 = 24597
        - 저전력 USB-Serial 칩
    -->
    <usb-device vendor-id="1027" product-id="24597" />
</resources>
